// ── KaTeX loader ──────────────────────────────────────────────────────────────
function useKatex() {
  const [ready, setReady] = useState(false);
  useEffect(() => {
    if (window.katex) { setReady(true); return; }
    const s = document.createElement("script");
    s.src = "https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js";
    s.onload = () => {
      const s2 = document.createElement("script");
      s2.src = "https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/contrib/auto-render.min.js";
      s2.onload = () => setReady(true);
      document.head.appendChild(s2);
    };
    document.head.appendChild(s);
  }, []);
  return ready;
}

function renderKatex(el) {
  if (!el || !window.renderMathInElement) return;
  try {
    window.renderMathInElement(el, {
      delimiters: [
        { left: "\\(", right: "\\)", display: false },
        { left: "\\[", right: "\\]", display: true },
        { left: "$$", right: "$$", display: true },
        { left: "$", right: "$", display: false },
      ],
      throwOnError: false,
    });
  } catch (_) {}
}

// ── CALL ANTHROPIC ────────────────────────────────────────────────────────────
async function callClaude(messages, system) {
  const res = await fetch(ANTHROPIC_API, {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({
      model: "claude-sonnet-4-20250514",
      max_tokens: 1800,
      system,
      messages,
    }),
  });
  if (!res.ok) {
    const e = await res.json().catch(() => ({}));
    throw new Error(e?.error?.message || `HTTP ${res.status}`);
  }
  const d = await res.json();
  return d.content.map((c) => c.text || "").join("").trim();
}

// ── MAIN COMPONENT ────────────────────────────────────────────────────────────
export default function MathGenius() {
  const katexReady = useKatex();
  const [theme, setTheme] = useState("dark");
  const [tab, setTab] = useState("type");
  const [input, setInput] = useState("");
  const [imageB64, setImageB64] = useState(null);
  const [imagePreview, setImagePreview] = useState(null);
  const [dragging, setDragging] = useState(false);

  const [phase, setPhase] = useState("idle"); // idle | loading | result | error
  const [loadStep, setLoadStep] = useState(0);
  const [result, setResult] = useState(null);
  const [ocrText, setOcrText] = useState("");
  const [error, setError] = useState("");

  const [history, setHistory] = useState(() => {
    try { return JSON.parse(localStorage.getItem("mg_history") || "[]"); } catch { return []; }
  });

  const resultsRef = useRef(null);
  const fileRef = useRef(null);
  const intervalRef = useRef(null);

  // inject CSS once
  useEffect(() => {
    const id = "mg-css";
    if (!document.getElementById(id)) {
      const el = document.createElement("style");
      el.id = id; el.textContent = CSS;
      document.head.appendChild(el);
    }
  }, []);

  // re-render KaTeX when result changes
  useEffect(() => {
    if (result && katexReady) {
      setTimeout(() => renderKatex(resultsRef.current), 150);
    }
  }, [result, katexReady]);

  // loading step ticker
  useEffect(() => {
    if (phase === "loading") {
      setLoadStep(0);
      let i = 0;
      intervalRef.current = setInterval(() => {
        i++;
        setLoadStep(i);
        if (i >= LOADING_MSGS.length - 1) clearInterval(intervalRef.current);
      }, 900);
    } else {
      clearInterval(intervalRef.current);
    }
    return () => clearInterval(intervalRef.current);
  }, [phase]);

  const saveHistory = useCallback((problem, topic, answer) => {
    if (!problem) return;
    const item = {
      problem: String(problem).slice(0, 110),
      topic: topic || "Math",
      answer: answer || "",
      time: new Date().toLocaleString(),
    };
    setHistory((prev) => {
      const next = [item, ...prev].slice(0, 20);
      try { localStorage.setItem("mg_history", JSON.stringify(next)); } catch (_) {}
      return next;
    });
  }, []);

  const processFile = (file) => {
    if (!file || !file.type.startsWith("image/")) return;
    const reader = new FileReader();
    reader.onload = (e) => {
      setImageB64(e.target.result);
      setImagePreview(e.target.result);
      setError("");
    };
    reader.readAsDataURL(file);
  };

  const SYSTEM = `You are an expert math teacher for grades 1–12.
Solve math problems fully, step by step.
IMPORTANT: Respond with ONLY a raw JSON object — no markdown fences, no extra text, no explanation outside JSON.
The JSON must follow the exact schema given. Invalid JSON will break the app.`;

  const SCHEMA = `{
  "extracted_problem": "string — the exact problem text",
  "topic": "string — e.g. Algebra, Calculus, Trigonometry, Geometry, Statistics",
  "subtopic": "string — specific concept",
  "answer": "string — concise final answer",
  "steps": [
    { "title": "string", "description": "string", "math": "string — LaTeX without delimiters, or empty string" }
  ],
  "explanation": "string — 2-3 sentences on the method/concept",
  "concepts": ["string"],
  "youtube_queries": ["string — 4 descriptive YouTube search queries"]
}`;

  async function solve(text, b64) {
    setPhase("loading");
    setError("");
    setResult(null);
    setOcrText("");

    try {
      const content = [];
      if (b64) {
        const mime = b64.split(";")[0].split(":")[1] || "image/jpeg";
        content.push({ type: "image", source: { type: "base64", media_type: mime, data: b64.split(",")[1] } });
        content.push({ type: "text", text: `Extract the math problem from this image and solve it completely.\nRespond with ONLY this JSON schema:\n${SCHEMA}` });
      } else {
        content.push({ type: "text", text: `Solve this math problem: "${text}"\n\nRespond with ONLY this JSON schema:\n${SCHEMA}` });
      }

      const raw = await callClaude([{ role: "user", content }], SYSTEM);

      // robust JSON extraction
      let parsed;
      const cleaned = raw.replace(/```(?:json)?|```/g, "").trim();
      const start = cleaned.indexOf("{");
      const end = cleaned.lastIndexOf("}");
      if (start === -1 || end === -1) throw new Error("No JSON in response. Please try again.");
      parsed = JSON.parse(cleaned.slice(start, end + 1));

      if (!parsed.answer && !parsed.steps) throw new Error("Incomplete response. Please try again.");

      if (b64 && parsed.extracted_problem) setOcrText(parsed.extracted_problem);

      setResult(parsed);
      setPhase("result");
      saveHistory(text || parsed.extracted_problem, parsed.topic, parsed.answer);

      setTimeout(() => {
        resultsRef.current?.scrollIntoView({ behavior: "smooth", block: "start" });
      }, 100);
    } catch (e) {
      setError(e.message || "Something went wrong. Please try again.");
      setPhase("error");
    }
  }

  function handleSolveTyped() {
    const t = input.trim();
    if (!t) { setError("Please enter a math problem first."); setPhase("error"); return; }
    solve(t, null);
  }

  function handleSolveImage() {
    if (!imageB64) { setError("Please upload an image first."); setPhase("error"); return; }
    solve(null, imageB64);
  }

  const light = theme === "light";
  const FALLBACK_IDS = ["tGFiCslE8bc", "IWigaRMiKHs", "mFnzSlLBXnQ", "IlNAJl36-10", "Qyd_v3DGzTM"];

  return (
    <div className={light ? "light" : ""} style={{ minHeight: "100vh" }}>
      {/* NAV */}
      <nav className="nav">
        <div className="nav-logo">MathGenius</div>
        <div className="nav-r">
          <button className="nbtn" onClick={() => document.getElementById("hist-anchor")?.scrollIntoView({ behavior: "smooth" })}>📚 History</button>
          <button className="theme-btn" onClick={() => setTheme(light ? "dark" : "light")}>{light ? "🌙" : "☀️"}</button>
        </div>
      </nav>

      <div className="page">
        {/* HERO */}
        <section className="hero">
          <div className="badge">⚡ AI-Powered · Grade 1–12</div>
          <h1 className="hero-h1">Solve Any Math Problem<br /><em>Instantly</em></h1>
          <p className="hero-sub">Type or photograph any problem — get step-by-step solutions, clear explanations, and YouTube lessons.</p>
          <div className="tags">
            {["Algebra","Trigonometry","Calculus","Geometry","Statistics","Matrices","Probability","Quadratics"].map(t => (
              <span key={t} className="tag">{t}</span>
            ))}
          </div>
        </section>

        {/* SOLVER CARD */}
        <div className="card-wrap">
          <div className="solver-card">
            {/* TABS */}
            <div className="tabs">
              <button className={`tab-btn ${tab === "type" ? "on" : ""}`} onClick={() => setTab("type")}>✏️ Type Problem</button>
              <button className={`tab-btn ${tab === "image" ? "on" : ""}`} onClick={() => setTab("image")}>📷 Upload Image</button>
            </div>

            {/* TYPE PANE */}
            <div className={`tab-pane ${tab === "type" ? "on" : ""}`}>
              <label className="lbl">Enter your math problem</label>
              <textarea
                className="math-ta"
                value={input}
                onChange={e => setInput(e.target.value)}
                placeholder={"e.g. Solve x² + 5x + 6 = 0\nor: Find the derivative of f(x) = 3x³ - 2x\nor: If sin(θ) = 3/5, find cos(θ) and tan(θ)"}
                onKeyDown={e => { if (e.ctrlKey && e.key === "Enter") handleSolveTyped(); }}
              />
              <div className="quick-row">
                {EXAMPLES.map(ex => (
                  <button key={ex.label} className="qbtn" onClick={() => setInput(ex.q)}>{ex.label}</button>
                ))}
              </div>
              {phase === "error" && tab === "type" && <div className="err-box">⚠️ {error}</div>}
              <button className="solve-btn" onClick={handleSolveTyped} disabled={phase === "loading"}>
                <span>✨</span><span>{phase === "loading" ? "Solving…" : "Solve Problem"}</span>
              </button>
            </div>

            {/* IMAGE PANE */}
            <div className={`tab-pane ${tab === "image" ? "on" : ""}`}>
              <div
                className={`drop-zone${dragging ? " drag" : ""}`}
                onDragOver={e => { e.preventDefault(); setDragging(true); }}
                onDragLeave={() => setDragging(false)}
                onDrop={e => { e.preventDefault(); setDragging(false); processFile(e.dataTransfer.files[0]); }}
                onClick={() => fileRef.current?.click()}
              >
                <input ref={fileRef} type="file" accept="image/*" style={{ display: "none" }} onChange={e => processFile(e.target.files[0])} />
                <span className="drop-icon">📸</span>
                <div className="drop-title">Drop your image here</div>
                <div className="drop-sub">or click to browse — PNG, JPG, JPEG supported</div>
              </div>

              {imagePreview && (
                <>
                  <img src={imagePreview} className="preview-img" alt="Preview" />
                  {ocrText && (
                    <div className="ocr-box">
                      <div className="ocr-lbl">📝 AI Vision — Extracted Text</div>
                      <div className="ocr-val">{ocrText}</div>
                    </div>
                  )}
                </>
              )}
              {phase === "error" && tab === "image" && <div className="err-box" style={{ marginTop: 12 }}>⚠️ {error}</div>}
              <button className="solve-btn" style={{ marginTop: 18 }} onClick={handleSolveImage} disabled={phase === "loading"}>
                <span>🔍</span><span>{phase === "loading" ? "Solving…" : "Extract & Solve"}</span>
              </button>
            </div>

            {/* LOADING */}
            {phase === "loading" && (
              <div className="loading-pane">
                <div className="spinner" />
                <div className="loading-msg">{LOADING_MSGS[Math.min(loadStep, LOADING_MSGS.length - 1)]}</div>
                <div className="loading-steps">
                  {LOADING_MSGS.slice(0, loadStep).map((m, i) => (
                    <div key={i} className="lstep" style={{ animationDelay: "0s" }}>✓ {m}</div>
                  ))}
                </div>
              </div>
            )}

            {/* RESULTS */}
            {phase === "result" && result && (
              <div ref={resultsRef}>
                {/* ANSWER */}
                <div className="res-sec">
                  <div className="res-hdr">
                    <div className="res-ico ico-g">✅</div>
                    <div>
                      <div className="res-title">Answer</div>
                      <div className="res-sub">{result.topic || "Math"}{result.subtopic ? ` · ${result.subtopic}` : ""}</div>
                    </div>
                  </div>
                  <div className="ans-box">
                    <div className="ans-lbl">Final Answer</div>
                    <div className="ans-val">{result.answer || "See steps below"}</div>
                  </div>
                </div>

                <div className="divider" />

                {/* STEPS */}
                <div className="res-sec">
                  <div className="res-hdr">
                    <div className="res-ico ico-b">📐</div>
                    <div>
                      <div className="res-title">Step-by-Step Solution</div>
                      <div className="res-sub">Follow along with each step</div>
                    </div>
                  </div>
                  <div className="steps-list">
                    {(result.steps || []).map((s, i) => (
                      <div key={i} className="step-item" style={{ animationDelay: `${i * 0.07}s` }}>
                        <div className="step-num">{i + 1}</div>
                        <div className="step-body">
                          <div className="step-t">{s.title}</div>
                          <div className="step-d">{s.description}</div>
                          {s.math && <div className="step-math">\({s.math}\)</div>}
                        </div>
                      </div>
                    ))}
                  </div>
                </div>

                <div className="divider" />

                {/* EXPLANATION */}
                <div className="res-sec">
                  <div className="res-hdr">
                    <div className="res-ico ico-o">💡</div>
                    <div>
                      <div className="res-title">Explanation</div>
                      <div className="res-sub">Understand the concept</div>
                    </div>
                  </div>
                  <div className="expl-txt">{result.explanation}</div>
                  <div className="chips">
                    {(result.concepts || []).map((c, i) => <span key={i} className="chip">{c}</span>)}
                  </div>
                </div>

                <div className="divider" />

                {/* VIDEOS */}
                <div className="res-sec">
                  <div className="res-hdr">
                    <div className="res-ico ico-r">▶️</div>
                    <div>
                      <div className="res-title">Learn More on YouTube</div>
                      <div className="res-sub">Click any card to search YouTube</div>
                    </div>
                  </div>
                  <div className="vid-grid">
                    {(result.youtube_queries || []).slice(0, 4).map((q, i) => {
                      const vid = FALLBACK_IDS[i % FALLBACK_IDS.length];
                      return (
                        <a key={i} className="vid-card" href={`https://www.youtube.com/results?search_query=${encodeURIComponent(q)}`} target="_blank" rel="noopener noreferrer">
                          <div className="vid-thumb">
                            <img src={`https://img.youtube.com/vi/${vid}/mqdefault.jpg`} alt="" onError={e => e.target.style.display = "none"} />
                            <div className="vid-play"><div className="play-circle">▶</div></div>
                          </div>
                          <div className="vid-info">
                            <div className="vid-title">{q}</div>
                            <div className="vid-ch">🎬 Search on YouTube</div>
                          </div>
                        </a>
                      );
                    })}
                  </div>
                </div>
              </div>
            )}
          </div>
        </div>

        {/* HISTORY */}
        <div className="hist-sec" id="hist-anchor">
          <div className="sec-title">📚 <span>Recent Problems</span></div>
          {history.length === 0
            ? <div className="hist-empty">No problems solved yet. Try one above!</div>
            : (
              <div className="hist-list">
                {history.map((item, i) => (
                  <div key={i} className="hist-item" onClick={() => { setInput(item.problem); setTab("type"); window.scrollTo({ top: 0, behavior: "smooth" }); }}>
                    <span style={{ fontSize: "1.2rem" }}>🔢</span>
                    <div className="hist-body">
                      <div className="hist-q">{item.problem}</div>
                      <div className="hist-time">{item.time}</div>
                    </div>
                    <div className="hist-badge">{item.topic}</div>
                  </div>
                ))}
              </div>
            )
          }
        </div>
      </div>
    </div>
  );
}
